generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:Prince%40005.@localhost:3307/websitedb"
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  createdAt DateTime    @default(now())
  status    OrderStatus @default(ORDER_ITEMS)
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]

  @@map("order")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("orderitem")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  description String?
  image       String?
  items       OrderItem[]

  @@map("product")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  email    String   @unique
  password String
  role     Role     @default(USER)
  orders   Order[]

  @@map("user")
}

enum OrderStatus {
  ORDER_ITEMS
  CONFIRMED
  PROCESSING
  DELIVERED
  CANCELLED

  @@map("order_status")
}

enum Role {
  USER
  ADMIN

  @@map("user_role")
}
